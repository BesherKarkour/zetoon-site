---
import Base from '../layouts/Base.astro';
import type { AppInfo } from '../data/apps';

interface Props {
  app: AppInfo;
}

const { app } = Astro.props;

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: app.name,
  description: app.description,
  applicationCategory: app.category,
  operatingSystem: 'Android',
  image: new URL(app.icon, Astro.site).href,
  url: new URL(Astro.url.pathname, Astro.site).href,
  author: {
    '@type': 'Organization',
    name: 'Zetoon',
    url: new URL('/', Astro.site).href,
  },
  ...(app.playUrl
    ? {
        installUrl: app.playUrl,
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      }
    : {}),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: app.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schema = app.faqs.length > 0 ? [appSchema, faqSchema] : appSchema;
---

<Base
  title={`${app.name} — ${app.tagline}`}
  description={app.description}
  ogImage={`/images/og-${app.slug}.png`}
  schema={schema}
>
  <div class="container">
    <section class="app-hero">
      <img class="app-icon" src={app.icon} alt={`${app.name} app icon`} width="128" height="128" />
      <h1>{app.name}</h1>
      <p class="lede">{app.tagline}</p>

      {
        app.status === 'live' && app.playUrl ? (
          <div class="store-badges">
            <a href={app.playUrl}>
              <img
                src="/images/google-play-badge.png"
                alt="Get it on Google Play"
                height="60"
                width="155"
              />
            </a>
          </div>
        ) : (
          <span class="status-pill">{app.statusLabel}</span>
        )
      }
    </section>

    <section class="block">
      <p class="lede" style="text-align:center; max-width: 42rem; margin-inline:auto;">
        {app.description}
      </p>
    </section>

    <section class="block">
      <h2>Features</h2>
      <div class="feature-grid">
        {
          app.features.map((f) => (
            <div class="feature">
              <span class="emoji">{f.emoji}</span>
              <h3>{f.title}</h3>
              <p>{f.text}</p>
            </div>
          ))
        }
      </div>
    </section>

    {
      app.faqs.length > 0 && (
        <section class="block">
          <h2>Frequently asked questions</h2>
          <div class="faq-list">
            {app.faqs.map((f) => (
              <details class="faq">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    <slot />
  </div>
</Base>
